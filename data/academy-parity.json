      {
        "id": "where-vs-having",
        "title": "WHERE versus HAVING",
        "trigger": "having",
        "feedback": "WHERE filters rows before aggregation; HAVING filters groups after aggregation."
      },
      {
        "id": "inner-left",
        "title": "INNER versus LEFT JOIN",
        "trigger": "join",
        "feedback": "Use LEFT JOIN when unmatched left-side rows must remain."
      },
